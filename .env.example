# ============================================================
# shopify-price-updater — environment variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# On Railway: add these under Variables in your service settings.
# ============================================================


# ── Socket server (shared across all stores) ─────────────────
SOCKET_SERVER_URL=https://duumy.com
SOCKET_SECRET_KEY=ananana!11


# ── HTTP server ───────────────────────────────────────────────
PORT=3001

# Admin secret for POST /rates — set a strong random string
ADMIN_SECRET=

# CORS origin for the admin dashboard / rates panel
# Set to your admin UI domain e.g. https://admin.yourdomain.com
# Leave as * during development only
ADMIN_ORIGIN=*


# ── Aura store ────────────────────────────────────────────────
# Supported types: jewellery / bullion / silver
# Metafield keys: gold_weight, karat, making_pct, price_category

AURA_SHOPIFY_STORE=aura-store.myshopify.com
AURA_SHOPIFY_TOKEN=

# Optional: override seeded DJG rates for Aura (JSON string)
# If not set, uses the hardcoded defaults in stores/aura.js
# AURA_DJG_RATES={"24K":582.25,"22K":539.00,"21K":517.00,"18K":443.00,"14K":345.50}


# ── Faqeesh store ─────────────────────────────────────────────
# Supported types: jewellery / bullion (no silver)
# Metafield keys: gold_grams, gold_karat, making_charges, is_bullion

FAQEESH_SHOPIFY_STORE=faqeesh-store.myshopify.com
FAQEESH_SHOPIFY_TOKEN=

# Optional: override seeded DJG rates for Faqeesh (JSON string)
# Rates are shared — updating via POST /rates updates both stores.
# This env var only sets the initial seed value on startup.
# FAQEESH_DJG_RATES={"24K":582.25,"22K":539.00,"21K":517.00,"18K":443.00,"14K":345.50}
